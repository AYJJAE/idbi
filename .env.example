# NEXUS API Configuration

NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Gemini AI Integration
# Obtain an API key from Google AI Studio: https://aistudio.google.com/
# The application will use mock data if this is empty or disabled.
GEMINI_API_KEY=

# Set this to "true" to force disable AI integration in public environments
# NEXT_PUBLIC_DISABLE_AI=true
